# ============================================================
# AdLauncher environment template
# Copy this file to .env.local for local development or .env for Docker.
#
# IMPORTANT:
# - Do not put real production secrets in this example file.
# - Values prefixed with NEXT_PUBLIC_ are exposed to browser JavaScript.
# - Never put service role keys, app secrets, database passwords, or private
#   Cloudflare service token secrets in NEXT_PUBLIC_ variables.
# ============================================================

# ============================================================
# 1. App URLs
# ============================================================

# Public base URL of the web app.
# Used by OAuth redirects, invite links, emails, absolute callback URLs, and
# some server-side redirects.
#
# Local:
#   http://localhost:3000
#
# Production:
#   https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server-side base URL used when the app needs to call itself from the server,
# for example to trigger cron upload immediately after a video finalize.
# Usually set this to the same value as NEXT_PUBLIC_APP_URL in production.
# If omitted, code falls back to VERCEL_URL or NEXT_PUBLIC_APP_URL where possible.
APP_URL=http://localhost:3000

# Legacy/fallback server-side URL used by email helpers if NEXT_PUBLIC_APP_URL
# is missing. Usually not needed if NEXT_PUBLIC_APP_URL is set.
SERVER_URL=http://localhost:3000

# ============================================================
# 2. Custom auth session
# ============================================================

# Secret used to sign the app's custom JWT session cookie:
#   adlauncher_session
#
# Production:
# - Must be a long random string.
# - Generate with a password manager or:
#     openssl rand -base64 48
CUSTOM_AUTH_SECRET=replace_with_long_random_secret

# Optional legacy fallback for custom auth.
# Keep empty unless an older deployment already uses JWT_SECRET.
JWT_SECRET=

# ============================================================
# 3. Supabase / Postgres
# ============================================================

# PostgreSQL schema used by Supabase PostgREST.
# This app expects ads_launcher unless your deployment intentionally uses public.
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=ads_launcher

# Supabase API URL.
# This tells the app which Supabase project/database API it points to.
#
# Supabase Cloud:
#   https://<project-ref>.supabase.co
#
# Self-hosted Supabase:
#   https://your-supabase-domain.example.com
#
# Where to find it:
#   Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-domain.example.com

# Optional internal Supabase URL for server-side/self-hosted deployments.
# Use this only when the server/container should call Supabase through an
# internal network address instead of the public gateway. Leave empty if unsure.
SUPABASE_INTERNAL_URL=

# Supabase anon/publishable key.
# Safe to expose to browser, but it must be paired with correct RLS policies.
#
# Where to find it:
#   Supabase Dashboard -> Project Settings -> API -> anon/public key
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=replace_with_anon_or_publishable_key

# Supabase service role key.
# Server-side only. Bypasses RLS. Never expose this in browser code.
#
# Used by:
# - server API routes that need admin DB access
# - storage signed uploads
# - migration/check scripts
#
# Where to find it:
#   Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=replace_with_service_role_key

# Direct Postgres connection string for maintenance scripts only.
# Used by backup/restore/migration commands, not by browser code.
#
# Example:
#   postgresql://postgres:password@host:5432/postgres
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Optional cloud DB connection used by inventory/migration helper scripts.
# Leave empty unless running scripts/migration-cloud-inventory.mjs or related
# migration diagnostics.
CLOUD_DATABASE_URL=
CLOUD_DB_HOSTADDR=
CLOUD_DB_PASSWORD=
CLOUD_PROJECT_REF=

# ============================================================
# 4. Lark OAuth / SSO
# ============================================================

# Lark is the company login/SSO provider.
#
# Where to configure:
#   Lark Developer Console -> your app -> Credentials / Security Settings
#
# Required redirect URL in Lark:
#   Local testing:
#     http://localhost:3000/api/auth/lark/callback
#
#   Production:
#     https://your-domain.com/api/auth/lark/callback
#
# Common setup checklist:
# - LARK_APP_ID must match the Lark app used for login.
# - LARK_APP_SECRET must come from the same Lark app.
# - NEXT_PUBLIC_APP_URL must match the domain used in Redirect URL.
# - The redirect URL must be added exactly in Lark, including protocol
#   http/https and path /api/auth/lark/callback.
# - In production, use HTTPS.

# Lark app/client ID. Usually starts with cli_.
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx

# Lark app/client secret. Server-side only.
LARK_APP_SECRET=replace_with_lark_app_secret

# Effective Lark redirect URL.
# The code builds this from NEXT_PUBLIC_APP_URL:
#   ${NEXT_PUBLIC_APP_URL}/api/auth/lark/callback
#
# This variable is documentation only; the app does not read it directly.
# Keep it here so installers know exactly what to paste into Lark.
LARK_REDIRECT_URL=http://localhost:3000/api/auth/lark/callback

# ============================================================
# 5. Facebook / Meta App
# ============================================================

# Meta app ID exposed to browser for login/connect UI.
# Where to find it:
#   developers.facebook.com -> App -> Settings -> Basic -> App ID
NEXT_PUBLIC_FACEBOOK_APP_ID=replace_with_meta_app_id

# Meta app ID used server-side. Usually same as NEXT_PUBLIC_FACEBOOK_APP_ID.
FACEBOOK_APP_ID=replace_with_meta_app_id

# Meta app secret. Server-side only.
# Where to find it:
#   developers.facebook.com -> App -> Settings -> Basic -> App Secret
FACEBOOK_APP_SECRET=replace_with_meta_app_secret

# Optional. If present, /api/inspo/adscan uses SearchAPI's Meta Ad Library
# integration first. This is the recommended path for competitor ads with
# thumbnails/media because Meta's official API is limited.
SEARCHAPI_API_KEY=4NX82PzhWckwuh6jh9MpG8zi

# Optional official Meta Ad Library token fallback. Requires Ad Library API
# authorization from facebook.com/ads/library/api.
FACEBOOK_AD_LIBRARY_TOKEN=replace_with_meta_ad_library_token

# Required OAuth callback URL in Meta:
#   Local testing, if Meta app allows it:
#     http://localhost:3000/api/auth/facebook/callback
#
#   Production:
#     https://your-domain.com/api/auth/facebook/callback
#
# The code builds this from NEXT_PUBLIC_APP_URL:
#   ${NEXT_PUBLIC_APP_URL}/api/auth/facebook/callback
FACEBOOK_REDIRECT_URL=http://localhost:3000/api/auth/facebook/callback

# ============================================================
# 6. Google Drive / Sheets integrations
# ============================================================

# Browser-side Google OAuth client ID.
# Required by UI flows that open Google Picker or request a Google token.
# This is the variable currently read by the frontend.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id

# Browser-side Google API key for Google Picker / Drive API client flows.
# This value is public by design; restrict it by HTTP referrer in Google Cloud.
NEXT_PUBLIC_GOOGLE_API_KEY=replace_with_google_browser_api_key

# Optional alias kept for documentation/backward compatibility.
# If you only set one value, set NEXT_PUBLIC_GOOGLE_CLIENT_ID.
GOOGLE_CLIENT_ID=replace_with_google_oauth_client_id

# Google OAuth client secret. Server-side only.
GOOGLE_CLIENT_SECRET=replace_with_google_oauth_client_secret

# Google redirect URL used by /api/google/connect.
# The code builds this from NEXT_PUBLIC_APP_URL:
#   ${NEXT_PUBLIC_APP_URL}/api/google/connect
GOOGLE_REDIRECT_URL=http://localhost:3000/api/google/connect

# Google Sheets — Service Account (no OAuth needed for sheets trigger)
#
# How to set up:
#   1. Google Cloud Console → IAM & Admin → Service Accounts → Create
#   2. Enable Google Sheets API in the project
#   3. Create a key (JSON) and download it
#   4. Paste the ENTIRE JSON content (single line) as GOOGLE_SERVICE_ACCOUNT_JSON
#   5. Tell users to share their sheet with the client_email from the JSON (Viewer access)
#
# NEXT_PUBLIC_SHEETS_SERVICE_ACCOUNT is shown in the UI so users know which email to share with.
# It must match the client_email field inside GOOGLE_SERVICE_ACCOUNT_JSON.
NEXT_PUBLIC_SHEETS_SERVICE_ACCOUNT=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"your-service-account@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ============================================================
# 7. Email - Resend
# ============================================================

# Resend API key used for organization invitations and transactional emails.
# If empty, invite/add-to-org emails will be skipped/logged.
RESEND_API_KEY=replace_with_resend_api_key

# ============================================================
# 8. AI providers
# ============================================================

# Optional global fallback keys for AI features.
# The app can also store per-organization AI keys in the database.
OPENAI_API_KEY=replace_with_openai_api_key
GEMINI_API_KEY=replace_with_gemini_api_key

# ============================================================
# 9. Cloudflare Access
# ============================================================

# Optional service token for server-side requests through Cloudflare Zero Trust.
# Required only if Supabase or internal APIs are protected behind Cloudflare
# Access and need service-token headers.
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=

# Optional browser-side Cloudflare Access headers.
# WARNING: NEXT_PUBLIC_ values are visible in browser bundles. Only use these
# if your infrastructure intentionally allows exposing this token to clients.
# In most production setups, leave NEXT_PUBLIC_CF_ACCESS_CLIENT_SECRET empty.
NEXT_PUBLIC_CF_ACCESS_CLIENT_ID=
NEXT_PUBLIC_CF_ACCESS_CLIENT_SECRET=

# ============================================================
# 10. Cron / internal jobs
# ============================================================

# Shared secret protecting internal cron endpoints:
# - /api/cron/upload-to-facebook
# - /api/cron/activate-scheduled-ads
#
# Cron callers must send:
#   Authorization: Bearer <CRON_SECRET>
CRON_SECRET=replace_with_cron_secret

# ============================================================
# 11. API cache, rate-limit, and performance tuning
# ============================================================

# Default max number of creatives returned by list endpoints.
CREATIVES_DEFAULT_LIMIT=200

# Cache TTLs in milliseconds for high-traffic Meta/Facebook metadata endpoints.
PAGES_CACHE_TTL_MS=600000
ADSETS_CACHE_TTL_MS=300000
AD_MEDIA_CACHE_TTL_MS=600000
EXISTING_ADS_CACHE_TTL_MS=300000
CREATIVES_CLIENT_CACHE_TTL_MS=90000
