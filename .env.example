# ============================================================
# Supabase
# Settings → API trong Supabase Dashboard
# ============================================================

# Project URL (Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# anon/public key (Settings → API → Project API keys → anon public)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# service_role key — CHỈ dùng server-side, KHÔNG expose ra client
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxx

# ============================================================
# Facebook / Meta App
# developers.facebook.com → My Apps → chọn app → Settings → Basic
# ============================================================

# App ID (public — dùng ở cả client và server)
NEXT_PUBLIC_FACEBOOK_APP_ID=5094268077359772
FACEBOOK_APP_ID=5094268077359772

# App Secret — CHỈ dùng server-side
FACEBOOK_APP_SECRET=your_facebook_app_secret_here

# ============================================================
# App URL
# URL public của app, dùng để tạo redirect URI và email links
# Dev: http://localhost:3000
# Prod: https://your-domain.com
# ============================================================

NEXT_PUBLIC_APP_URL=https://www.sonkieu.site

# ============================================================
# Resend — Email
# resend.com → API Keys
# ============================================================

RESEND_API_KEY=re_KLuqv5cz_ASVJCGC5RGbLfo2SfU9q56mM

# ============================================================
# Google Gemini — AI features (Inspo AI tab)
# aistudio.google.com/apikey
# ============================================================
GEMINI_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Cloudflare Access — Service Token (nếu Supabase đằng sau CF Zero Trust)
# Zero Trust → Access → Service Auth → Service Tokens → Create Token
# ============================================================
CF_ACCESS_CLIENT_ID=
CF_ACCESS_CLIENT_SECRET=
NEXT_PUBLIC_CF_ACCESS_CLIENT_ID=
NEXT_PUBLIC_CF_ACCESS_CLIENT_SECRET=

# Schema PostgreSQL riêng (nếu không dùng public)
NEXT_PUBLIC_SUPABASE_DB_SCHEMA=ads_launcher

# Custom auth secret cho JWT nội bộ (không dùng Supabase Auth)
CUSTOM_AUTH_SECRET=

# ============================================================
# API Rate-Limit & Performance Tuning (optional overrides)
# Các giá trị này không bắt buộc — server dùng default nếu không set
# ============================================================

# Số creatives tối đa trả về mỗi lần (default 200, max 500)
# CREATIVES_DEFAULT_LIMIT=200

# TTL (ms) cache server cho Meta API responses
# PAGES_CACHE_TTL_MS=600000        # 10 phút — pages/ig accounts
# ADSETS_CACHE_TTL_MS=300000       # 5 phút — adsets/campaigns
# AD_MEDIA_CACHE_TTL_MS=600000     # 10 phút — FB media library
# EXISTING_ADS_CACHE_TTL_MS=300000 # 5 phút — existing ads

# TTL (ms) client-side cache trong browser
# CREATIVES_CLIENT_CACHE_TTL_MS=90000  # 90s — creatives trong media dialog
